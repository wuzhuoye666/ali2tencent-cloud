<!DOCTYPE html>
<html lang="zh-CN">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>阿里云镜像迁移性能对比报告</title>
<style>
  * { box-sizing: border-box; margin: 0; padding: 0; }
  body { font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif; background: #f5f7fa; color: #333; }
  .container { max-width: 1100px; margin: 0 auto; padding: 24px; }
  header { background: linear-gradient(135deg, #1a73e8, #0d47a1); color: #fff; padding: 32px; border-radius: 12px; margin-bottom: 28px; }
  header h1 { font-size: 1.8rem; }
  header p { opacity: 0.85; margin-top: 6px; font-size: 0.95rem; }
  .card { background: #fff; border-radius: 10px; box-shadow: 0 2px 8px rgba(0,0,0,.08); padding: 24px; margin-bottom: 24px; }
  .card h2 { font-size: 1.1rem; color: #1a73e8; margin-bottom: 16px; border-left: 4px solid #1a73e8; padding-left: 10px; }
  table { width: 100%; border-collapse: collapse; font-size: 0.9rem; }
  th { background: #f0f4ff; color: #444; font-weight: 600; padding: 10px 14px; text-align: left; border-bottom: 2px solid #d0d9ff; }
  td { padding: 10px 14px; border-bottom: 1px solid #eee; }
  tr:hover td { background: #f8faff; }
  .badge { display: inline-block; padding: 2px 10px; border-radius: 20px; font-size: 0.78rem; font-weight: 600; }
  .badge-green { background: #e6f4ea; color: #1e7e34; }
  .badge-blue  { background: #e8f0fe; color: #1a73e8; }
  .badge-gray  { background: #f1f3f4; color: #666; }
  .metric-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(180px, 1fr)); gap: 16px; }
  .metric-box { border: 1px solid #e0e0e0; border-radius: 8px; padding: 16px; text-align: center; }
  .metric-box .val { font-size: 2rem; font-weight: 700; color: #1a73e8; }
  .metric-box .lbl { font-size: 0.78rem; color: #888; margin-top: 4px; }
  .best { background: #e6f4ea; border-color: #a8d5b5; }
  .best .val { color: #1e7e34; }
  footer { text-align: center; color: #aaa; font-size: 0.82rem; margin-top: 32px; padding: 16px; }
  .empty { color: #aaa; text-align: center; padding: 40px; }
</style>
</head>
<body>
<div class="container">
  <header>
    <h1>阿里云镜像迁移 · 性能对比报告</h1>
    <p>生成时间：{{ generated_at }}　|　共测试版本：{{ results|length }}</p>
  </header>

  {% if results %}
  <!-- 汇总指标（最新版本） -->
  {% set latest = results[0] %}
  <div class="card">
    <h2>最新版本概况（{{ latest.version }}）</h2>
    <div class="metric-grid">
      <div class="metric-box {% if latest.cpu_score == max_cpu %}best{% endif %}">
        <div class="val">{{ "%.0f"|format(latest.cpu_score or 0) }}</div>
        <div class="lbl">CPU Events/s</div>
      </div>
      <div class="metric-box {% if latest.mem_score == max_mem %}best{% endif %}">
        <div class="val">{{ "%.0f"|format(latest.mem_score or 0) }}</div>
        <div class="lbl">内存 MB/s</div>
      </div>
      <div class="metric-box {% if latest.disk_read_mb == max_disk_r %}best{% endif %}">
        <div class="val">{{ "%.0f"|format(latest.disk_read_mb or 0) }}</div>
        <div class="lbl">磁盘读 MB/s</div>
      </div>
      <div class="metric-box {% if latest.disk_write_mb == max_disk_w %}best{% endif %}">
        <div class="val">{{ "%.0f"|format(latest.disk_write_mb or 0) }}</div>
        <div class="lbl">磁盘写 MB/s</div>
      </div>
      <div class="metric-box {% if latest.net_bandwidth_mb == max_net %}best{% endif %}">
        <div class="val">{{ "%.0f"|format(latest.net_bandwidth_mb or 0) }}</div>
        <div class="lbl">网络 MB/s</div>
      </div>
    </div>
  </div>

  <!-- 多版本对比表 -->
  <div class="card">
    <h2>多版本性能对比</h2>
    <table>
      <thead>
        <tr>
          <th>版本</th>
          <th>测试时间</th>
          <th>CPU Events/s</th>
          <th>内存 MB/s</th>
          <th>磁盘读 MB/s</th>
          <th>磁盘写 MB/s</th>
          <th>网络 MB/s</th>
          <th>OS</th>
          <th>内核</th>
        </tr>
      </thead>
      <tbody>
        {% for r in results %}
        <tr>
          <td><span class="badge badge-blue">{{ r.version }}</span></td>
          <td>{{ r.tested_at }}</td>
          <td {% if r.cpu_score == max_cpu %}class="best"{% endif %}>{{ "%.1f"|format(r.cpu_score or 0) }}</td>
          <td {% if r.mem_score == max_mem %}class="best"{% endif %}>{{ "%.1f"|format(r.mem_score or 0) }}</td>
          <td {% if r.disk_read_mb == max_disk_r %}class="best"{% endif %}>{{ "%.1f"|format(r.disk_read_mb or 0) }}</td>
          <td {% if r.disk_write_mb == max_disk_w %}class="best"{% endif %}>{{ "%.1f"|format(r.disk_write_mb or 0) }}</td>
          <td {% if r.net_bandwidth_mb == max_net %}class="best"{% endif %}>{{ "%.1f"|format(r.net_bandwidth_mb or 0) }}</td>
          <td>{{ r.os_release or '-' }}</td>
          <td>{{ r.kernel or '-' }}</td>
        </tr>
        {% endfor %}
      </tbody>
    </table>
    <p style="margin-top:10px;font-size:0.8rem;color:#aaa;">绿色高亮为当前最优值</p>
  </div>

  <!-- 流水线任务历史 -->
  <div class="card">
    <h2>流水线任务历史</h2>
    <table>
      <thead>
        <tr>
          <th>版本</th>
          <th>阶段</th>
          <th>状态</th>
          <th>开始时间</th>
          <th>结束时间</th>
          <th>错误信息</th>
        </tr>
      </thead>
      <tbody>
        {% for t in tasks %}
        <tr>
          <td>{{ t.version }}</td>
          <td>{{ t.stage }}</td>
          <td>
            {% if t.status == 'done' %}<span class="badge badge-green">done</span>
            {% elif t.status == 'failed' %}<span class="badge" style="background:#fce8e8;color:#c62828">failed</span>
            {% elif t.status == 'running' %}<span class="badge badge-blue">running</span>
            {% else %}<span class="badge badge-gray">{{ t.status }}</span>{% endif %}
          </td>
          <td>{{ t.started_at or '-' }}</td>
          <td>{{ t.finished_at or '-' }}</td>
          <td style="font-size:0.78rem;color:#c62828">{{ (t.error_msg or '')[:80] }}</td>
        </tr>
        {% endfor %}
      </tbody>
    </table>
  </div>

  {% else %}
  <div class="card"><div class="empty">暂无测试数据，请先运行 <code>python main.py run</code></div></div>
  {% endif %}

  <footer>ali2tencent-cloud pipeline · 自动生成报告 · {{ generated_at }}</footer>
</div>
</body>
</html>
