# ============ 腾讯云基础凭证 ============
TENCENT_SECRET_ID=
TENCENT_SECRET_KEY=
TENCENT_REGION=ap-guangzhou
TENCENT_COS_BUCKET=

# ============ 阿里云镜像检测 ============
# 阿里云 Alibaba Cloud Linux 镜像发布页
ALI_IMAGE_DOC_URL=https://mirrors.aliyun.com/alinux/
# 定时检测间隔（小时）
CHECK_INTERVAL_HOURS=6

# ============ CVM 实例参数 ============
CVM_INSTANCE_TYPE=S5.MEDIUM2
CVM_VPC_ID=
CVM_SUBNET_ID=
CVM_SECURITY_GROUP_ID=
CVM_LOGIN_PASSWORD=Ali2Tencent@2024
CVM_DISK_SIZE=50

# ============ SSH / 性能测试 ============
SSH_USER=root
# 优先使用私钥；若留空则使用 CVM_LOGIN_PASSWORD
SSH_PRIVATE_KEY_PATH=
# 单项测试超时（秒）
BENCHMARK_TIMEOUT=300

# ============ 运行行为 ============
# 测试完成后是否保留 CVM 实例（true/false）
KEEP_INSTANCE=false
# 目录配置（默认相对项目根目录）
TMP_DIR=./tmp
LOG_DIR=./logs
REPORT_DIR=./reports
STATE_DB=./state.db
